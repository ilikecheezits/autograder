<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" type="text/css" href="../theme.css" />
    <link rel="stylesheet" type="text/css" href="../profile.css" />
    <title>Problemset</title>
  </head>
  <body>
    <%- include("partials/header", {active: "problemset"}); %>
    <%- include("partials/particles", {depth: 1}); %>
    
    <div class="main-block">
      <div class="title">Problems</div>
    </div>
    <div class="main-block">
      <% for (let i=0; i<locals.problems.length; i++) { %>
      <ul class="sl">
        <li class="sl">
          <a href= <%= "/grade/problemset/" + locals.problems[i].id %> >
            <div class="problem-text">
              <%= locals.problems[i].name %>
            </div>
          </a>
        </li>
      </ul>
      <% } %>
    </div>
  </body>
</html> 