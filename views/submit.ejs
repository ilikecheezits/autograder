<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" type="text/css" href="../theme.css" />
    <link rel="stylesheet" type="text/css" href="../profile.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/ace/1.32.2/ace.js"></script>
    <title>Submit</title>
    <style>
      #editor {
        width: 100%;
        height: 400px;
        font-size: 14px;
        margin-bottom: 1em;
        border-radius: 4px;
      }
      #codeinput {
        width: 100%;
        height: 400px;
        font-size: 14px;
        font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', 'Consolas', monospace;
        display: none;
      }
      .button-container {
        margin-bottom: 1em;
      }
    </style>
  </head>
  <body>
    <%- include("partials/header", {active: "submit"}); %>
    <%- include("partials/particles", {depth: 1}); %>
    
    <div class="container">
      <div class="button-container">
        <button onclick="toggleTheme()" id="theme-toggle">Toggle Theme</button>
        <button onclick="toggleEditor()" id="editor-toggle">Switch Editor</button>
      </div>
      <form action="/grade/submit" method="POST">
        <div id="editor"></div>
        <textarea id="codeinput" name="code"></textarea>
        <input type="hidden" name="problem" value="<%= problem %>" />
        <button type="submit">Submit</button>
      </form>
    </div>

    <script>
      // Initialize Ace editor
      const editor = ace.edit("editor");
      editor.setTheme("ace/theme/monokai");
      editor.session.setMode("ace/mode/python");
      editor.setOptions({
        fontSize: "14px"
      });

      // Sync editor content with textarea
      editor.getSession().on('change', function() {
        document.getElementById('codeinput').value = editor.getSession().getValue();
      });

      // Theme toggle functionality
      function toggleTheme() {
        const theme = localStorage.getItem('theme') === 'light' ? 'dark' : 'light';
        localStorage.setItem('theme', theme);
        document.body.className = theme;
        editor.setTheme(theme === 'light' ? "ace/theme/chrome" : "ace/theme/monokai");
      }

      // Editor toggle functionality
      function toggleEditor() {
        const editorDiv = document.getElementById('editor');
        const textarea = document.getElementById('codeinput');
        
        if (editorDiv.style.display === 'none') {
          editorDiv.style.display = 'block';
          textarea.style.display = 'none';
          editor.setValue(textarea.value);
        } else {
          editorDiv.style.display = 'none';
          textarea.style.display = 'block';
          textarea.value = editor.getValue();
        }
      }

      // Set initial theme
      const currentTheme = localStorage.getItem('theme') || 'dark';
      document.body.className = currentTheme;
      editor.setTheme(currentTheme === 'light' ? "ace/theme/chrome" : "ace/theme/monokai");
    </script>
  </body>
</html> 